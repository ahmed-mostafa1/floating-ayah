{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noor Remind",
  "version": "0.1.0",
  "identifier": "app.noor-remind.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Noor Remind",
        "width": 1040,
        "height": 720,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../resources/quran.sqlite"]
  }
}
